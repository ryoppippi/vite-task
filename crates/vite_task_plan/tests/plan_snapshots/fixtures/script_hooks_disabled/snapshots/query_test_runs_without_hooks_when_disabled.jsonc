// run test
{
  "graph": [
    {
      "key": [
        "<workspace>/",
        "test"
      ],
      "node": {
        "task_display": {
          "package_name": "@test/script-hooks-disabled",
          "task_name": "test",
          "package_path": "<workspace>/"
        },
        "items": [
          {
            "execution_item_display": {
              "task_display": {
                "package_name": "@test/script-hooks-disabled",
                "task_name": "test",
                "package_path": "<workspace>/"
              },
              "command": "echo test",
              "and_item_index": null,
              "cwd": "<workspace>/"
            },
            "kind": {
              "Leaf": {
                "InProcess": {
                  "kind": {
                    "Echo": {
                      "strings": [
                        "test"
                      ],
                      "trailing_newline": true
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "neighbors": []
    }
  ],
  "concurrency_limit": 4
}
