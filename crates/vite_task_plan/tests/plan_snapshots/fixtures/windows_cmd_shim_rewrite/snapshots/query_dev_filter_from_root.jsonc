// run --filter ./packages/foo dev
{
  "graph": [
    {
      "key": [
        "<workspace>/packages/foo",
        "dev"
      ],
      "node": {
        "task_display": {
          "package_name": "foo",
          "task_name": "dev",
          "package_path": "<workspace>/packages/foo"
        },
        "items": [
          {
            "execution_item_display": {
              "task_display": {
                "package_name": "foo",
                "task_name": "dev",
                "package_path": "<workspace>/packages/foo"
              },
              "command": "vite --port 3000",
              "cwd": "<workspace>/packages/foo"
            },
            "kind": {
              "Leaf": {
                "Spawn": {
                  "cache_metadata": {
                    "spawn_fingerprint": {
                      "cwd": "packages/foo",
                      "program_fingerprint": {
                        "InsideWorkspace": {
                          "relative_program_path": "packages/foo/node_modules/.bin/vite.cmd"
                        }
                      },
                      "args": [
                        "--port",
                        "3000"
                      ],
                      "env_fingerprints": {
                        "fingerprinted_envs": {},
                        "untracked_env_config": [
                          "<default untracked envs>"
                        ]
                      }
                    },
                    "execution_cache_key": {
                      "UserTask": {
                        "task_name": "dev",
                        "command_item_index": 0,
                        "and_item_index": 0,
                        "extra_args": [],
                        "package_path": "packages/foo"
                      }
                    },
                    "input_config": {
                      "includes_auto": true,
                      "positive_globs": [],
                      "negative_globs": []
                    },
                    "output_config": {
                      "includes_auto": true,
                      "positive_globs": [],
                      "negative_globs": []
                    }
                  },
                  "spawn_command": {
                    "program_path": "<workspace>/packages/foo/node_modules/.bin/vite",
                    "args": [
                      "--port",
                      "3000"
                    ],
                    "spawn_envs": {
                      "FORCE_COLOR": "1",
                      "PATH": "<workspace>/packages/foo/node_modules/.bin:<workspace>/node_modules/.bin:<tools>"
                    },
                    "cwd": "<workspace>/packages/foo"
                  }
                }
              }
            }
          }
        ]
      },
      "neighbors": []
    }
  ],
  "concurrency_limit": 4
}
